---
// Import the necessary dependencies.
import AuthBtn from "@components/ui/buttons/AuthBtn.astro";
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import TextInput from "@components/ui/forms/input/TextInput.astro";
import EmailContactInput from "@components/ui/forms/input/EmailContactInput.astro";
import PhoneInput from "@components/ui/forms/input/PhoneInput.astro";
import TextAreaInput from "@components/ui/forms/input/TextAreaInput.astro";
import Icon from "@components/ui/icons/Icon.astro";

// Define the variables that will be used in this component
const title: string = "Entre em contato conosco";
const subTitle: string =
  "Tem dúvidas ou precisa de ajuda com seu projeto ou sua compra?<br/>Juntos encontraremos as melhores soluções com nossos materiais e serviços especializados.";
const formTitle: string = "Preencha o formulário abaixo e entraremos em contato em breve.";
const formSubTitle: string = "Retornaremos em breve.";

---

<!-- Contact Us -->
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400" set:html={subTitle}>
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        <!-- Form for user input with various input fields.-->
        <!-- Each field utilizes a different input component for the specific type of input (text, email, phone, and textarea)-->
        <form id="contact-form">
          <div class="grid gap-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="hs-firstname-contacts"
                label="Primeiro Nome"
                name="hs-firstname-contacts"
              />
              <TextInput
                id="hs-lastname-contacts"
                label="Sobrenome"
                name="hs-lastname-contacts"
              />
            </div>
            <EmailContactInput id="hs-email-contacts" />
            <PhoneInput id="hs-phone-number" />
            <TextAreaInput
              id="hs-about-contacts"
              label="Mensagem"
              name="hs-about-contacts"
            />
          </div>

          <div class="mt-4 grid">
            <AuthBtn title="Enviar Mensagem" />
          </div>

          <div class="mt-3 text-center">
            <p id="form-status" class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>

        <script is:inline>
          function initContactForm() {
            const form = document.getElementById("contact-form");
            const statusText = document.getElementById("form-status");

            // Se o formulário não existir na página, não faz nada
            if (!form) return;
            
            // Removemos um possível listener duplicado para evitar enviar 2 vezes
            form.onsubmit = async (e) => {
              e.preventDefault();
              if (!statusText) return;

              statusText.innerText = "A enviar mensagem...";
              statusText.style.color = "#ea580c"; // Laranja/Aviso

              try {
                const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwm4ZSqvKDu-o22xyMgmZYKM9y_sLOAPM66sDP9sdwIF8zoqF_kP922h0Cdg0kNdeNU/exec";
                const formData = new FormData(form);
                
                await fetch(GOOGLE_SCRIPT_URL, {
                  method: "POST",
                  body: formData,
                  mode: "no-cors" // Google Scripts requerem no-cors em HTML estático
                });

                statusText.innerHTML = "Mensagem enviada com sucesso!<br/>Entraremos em contato em breve.";
                statusText.style.color = "green";
                form.reset();
                
              } catch (error) {
                console.error(error);
                statusText.innerText = "Ocorreu um erro. Tenta novamente ou liga-nos diretamente.";
                statusText.style.color = "red";
              }
            };
          }

          // Executa quando a página carrega pela primeira vez
          document.addEventListener('DOMContentLoaded', initContactForm);
          // Executa também se mudares de página e voltares (por causa do sistema de navegação do Astro)
          document.addEventListener('astro:page-load', initContactForm);
        </script>
      </div>

      <!--ContactIconBlocks are used to display different methods of contacting, including visiting office, email, browsing knowledgebase, and FAQ.-->
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="FAQ"
          content="Explore nossa FAQ para respostas rápidas e claras para perguntas comuns."
          isLinkVisible={true}
          linkTitle="Visitar FAQs"
          linkURL="/#faq"
          isArrowVisible={true}
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Marcas Famosas Representações Comerciais LTDA"
          content="Atendemos os estados do Paraná e Santa Catarina."
          isAddressVisible={false}
          addressContent=""
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Contato por e-mail"
          content="Prefere o contato por e-mail? Envie-nos uma mensagem para:"
          isLinkVisible={true}
          linkTitle="wanderley@asmarcasfamosas.com.br"
          linkURL="mailto:wanderley@asmarcasfamosas.com.br"
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>
